{
  "name": "@hgwk/nsmk",
  "version": "0.1.0",
  "description": "Namo Sitebuilder migration kit",
  "license": "MIT",
  "author": "hgwk",
  "type": "module",
  "bin": {
    "nsmk": "bin/nsmk.mjs"
  },
  "files": [
    "bin",
    "scripts/analyze-sitebuilder-export.mjs",
    "scripts/build-token-admin-zip.mjs",
    "scripts/extract-wordpress-documents.mjs",
    "scripts/gen-dotted-map.mjs",
    "scripts/init-site.mjs",
    "scripts/mirror-document-images.mjs",
    "scripts/optimize-assets-fast.mjs",
    "scripts/verify-site-package.mjs",
    "scripts/verify-site-preview.mjs",
    "shared",
    "sites/_template",
    "sample",
    "src",
    "AGENTS.md",
    "CLAUDE.md",
    "LOCAL_PREVIEW.md",
    "LICENSE",
    "README.md",
    "README.en.md",
    "README.ja.md",
    "index.html",
    "vite.config.mjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hgwk/nsmk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "init:site": "node scripts/init-site.mjs",
    "dev": "vite --host 127.0.0.1",
    "dev:template": "SITE=_template vite --host 127.0.0.1",
    "optimize:assets": "node scripts/optimize-assets-fast.mjs",
    "extract:wordpress": "node scripts/extract-wordpress-documents.mjs",
    "mirror:documents": "node scripts/mirror-document-images.mjs",
    "analyze:sitebuilder": "node scripts/analyze-sitebuilder-export.mjs",
    "generate:dotted-map": "node scripts/gen-dotted-map.mjs",
    "pack": "node scripts/build-token-admin-zip.mjs",
    "pack:template": "SITE=_template node scripts/build-token-admin-zip.mjs",
    "verify:package": "node scripts/verify-site-package.mjs",
    "verify:preview": "node scripts/verify-site-preview.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "sharp": "^0.35.1",
    "svg-dotted-map": "^2.0.1"
  }
}
